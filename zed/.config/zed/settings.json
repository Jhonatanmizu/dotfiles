{
  "terminal": {
    "font_family": "MesloLGS Nerd Font",
    "font_fallbacks": [
      "CaskaydiaMono Nerd Font",
      "Fira code",
      "FiraCode Nerd Font"
    ],
    "max_scroll_history_lines": 0
  },
  "project_panel": {
    "entry_spacing": "standard",
    "auto_fold_dirs": false
  },
  "base_keymap": "VSCode",
  "minimap": {
    "show": "never"
  },
  "current_line_highlight": "gutter",
  "cursor_shape": "bar",
  "buffer_font_fallbacks": [
    "MesloLGS Nerd Font",
    "Fira code"
  ],
  "buffer_font_family": "FiraCode Nerd Font",
  "file_types": {
    "typescriptreact": [
      "*.tsx"
    ],
    "javascript": [
      "*.js"
    ],
    "javascriptreact": [
      "*.jsx"
    ],
    "html": [
      "*.xml",
      "*.svg",
      "*.html",
      "*.django-html"
    ],
    "django-html": [
      "**/templates/**/*.html",
      "**/base_templates/**/*.html"
    ],
    "pip-requirements": [
      "**/requirements{/**,*}.{txt,in}"
    ]
  },
  "colorize_brackets": true,
  "linked_edits": true,
  "wrap_guides": [
    80,
    120
  ],
  "toolbar": {
    "breadcrumbs": false,
    "quick_actions": false,
    "selections_menu": false
  },
  "git": {
    "inline_blame": {
      "enabled": false
    }
  },
  "edit_predictions": {
    "provider": "zed"
  },
  "cli_default_open_behavior": "new_window",
  "agent": {
    "default_model": {
      "provider": "google",
      "model": "gemini-2.5-flash",
      "enable_thinking": true
    },
    "favorite_models": [],
    "model_parameters": []
  },
  "agent_servers": {
    "opencode": {
      "type": "registry"
    },
    "kimi": {
      "type": "registry"
    },
    "gemini": {
      "type": "registry"
    },
    "github-copilot-cli": {
      "type": "registry"
    },
    "cursor": {
      "type": "registry"
    }
  },
  "icon_theme": "Catppuccin Macchiato",
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": {
    "mode": "dark",
    "light": "Ayu Light",
    "dark": "Tokyo Night Storm"
  }
}
